# =============================================================================
# Meeting Intelligence Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================================

# PostgreSQL connection string (used by backend and Celery workers)
DATABASE_URL=postgresql://postgres:postgrespassword@db:5432/meeting_agent

# Database connection pool configurations
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=True


# Redis connection string (used as Celery message broker)
REDIS_URL=redis://redis:6379/0

# Google Gemini API key (get one free at https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Anthropic Claude API key (get one at https://console.anthropic.com)
CLAUDE_API_KEY=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

LOG_LEVEL=INFO
